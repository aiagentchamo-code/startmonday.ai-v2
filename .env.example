# =============================================================================
# StartMonday.AI — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase  (https://supabase.com → Project Settings → API)
# Required for: authentication, dashboard, database persistence
# -----------------------------------------------------------------------------
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public site URL used for auth redirects (no trailing slash)
SITE_URL=http://localhost:4321

# -----------------------------------------------------------------------------
# Stripe  (https://dashboard.stripe.com/apikeys)
# Required for: checkout, billing portal, subscriptions
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# For local dev: stripe listen --forward-to localhost:4321/api/stripe-webhook

# -----------------------------------------------------------------------------
# SMTP / Email  (any SMTP provider: Gmail, SendGrid, Mailgun, etc.)
# Required for: contact form, subscribe, transactional emails
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# CONTACT_EMAIL=hello@startmonday.ai
# PUBLIC_PLAUSIBLE_DOMAIN=startmonday.ai
