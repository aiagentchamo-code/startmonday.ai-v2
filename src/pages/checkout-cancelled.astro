---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Checkout cancelled | StartMonday.AI" noindex={true}>
  <section class="container-content py-24 text-center">
    <span class="eyebrow">Checkout</span>
    <h1 class="mt-4">Checkout cancelled.</h1>
    <p class="mx-auto mt-4 max-w-xl text-graphite">
      No payment was made. You can choose a plan again whenever you are ready.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/sign-up" class="btn btn-primary">Return to signup</a>
      <a href="/pricing" class="btn btn-secondary">Compare plans</a>
    </div>
  </section>
</Layout>
