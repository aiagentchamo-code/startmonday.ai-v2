---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found | StartMonday.AI">
  <section class="container-content py-28 text-center">
    <span class="eyebrow">404</span>
    <h1 class="mt-4">This page went looking for Monday.</h1>
    <p class="mt-5 max-w-xl mx-auto text-lg text-graphite">The page you're after doesn't exist — or it moved. Try one of these:</p>
    <div class="mt-8 flex justify-center gap-3 flex-wrap">
      <a href="/" class="btn btn-primary">Take me home</a>
      <a href="/services" class="btn btn-secondary">Services</a>
      <a href="/contact" class="btn btn-secondary">Contact</a>
    </div>
  </section>
</Layout>
