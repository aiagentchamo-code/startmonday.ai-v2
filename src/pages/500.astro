---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Server error | StartMonday.AI" noindex={true}>
  <section class="container-content py-24 text-center">
    <span class="eyebrow">Error</span>
    <h1 class="mt-4">Something went wrong.</h1>
    <p class="mx-auto mt-4 max-w-xl text-graphite">
      We could not complete that request. Please refresh the page or contact us if the issue continues.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/" class="btn btn-primary">Go to homepage</a>
      <a href="/contact" class="btn btn-secondary">Contact support</a>
    </div>
  </section>
</Layout>
