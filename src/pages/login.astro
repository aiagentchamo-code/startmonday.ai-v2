---
import Layout from '../layouts/Layout.astro';

// Already logged in → go straight to dashboard
if (Astro.locals.user) return Astro.redirect('/dashboard');

const sent  = Astro.url.searchParams.has('sent');
const error = Astro.url.searchParams.get('error');

const errorMessages: Record<string, string> = {
  invalid_email: 'Please enter a valid email address.',
  send_failed:   'Could not send the login link. Please try again.',
  auth_failed:   'Login link expired or invalid. Request a new one.',
};
---
<Layout title="Log in | StartMonday.AI" noindex={true}>
  <section class="container-content flex min-h-[70vh] items-center justify-center py-24">
    <div class="w-full max-w-md">
      <span class="eyebrow">Account access</span>
      <h1 class="mt-4">Log in to your account</h1>
      <p class="mt-3 text-graphite">
        Enter the email you used at checkout. We'll send you a magic link — no password needed.
      </p>

      {sent && (
        <div class="mt-6 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
          Check your inbox for a login link. It expires in 1 hour.
        </div>
      )}

      {error && !sent && (
        <div class="mt-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
          {errorMessages[error] ?? 'Something went wrong. Please try again.'}
        </div>
      )}

      {!sent && (
        <form method="POST" action="/api/auth/login" class="mt-8 space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-graphite mb-1.5">
              Email address
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@company.com"
              class="w-full rounded-lg border border-stone-300 bg-white px-4 py-2.5 text-sm text-stone-900 placeholder:text-stone-400 focus:border-stone-900 focus:outline-none focus:ring-1 focus:ring-stone-900"
            />
          </div>
          <button type="submit" class="btn btn-primary w-full">
            Send login link
          </button>
        </form>
      )}

      {sent && (
        <div class="mt-6">
          <button
            onclick="window.location.search=''"
            class="btn btn-secondary w-full"
          >
            Use a different email
          </button>
        </div>
      )}

      <p class="mt-8 text-center text-sm text-graphite">
        Don't have a subscription yet?{' '}
        <a href="/sign-up" class="font-medium underline underline-offset-2">
          View plans
        </a>
      </p>
    </div>
  </section>
</Layout>
