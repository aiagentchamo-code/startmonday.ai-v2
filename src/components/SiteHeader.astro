---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHero = pathname === '/';
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};

const navLinks = [
  { href: '/',           label: 'Home' },
  {
    href: '/services',
    label: 'Services',
    children: [
      { href: '/services/ai-business-academy', label: 'AI Business Academy' },
      { href: '/services/startmonday',         label: 'StartMonday+' },
      { href: '/services/startforward',        label: 'StartForward' },
      { href: '/services/ai-solutions-lab',    label: 'AI Solutions Lab' },
    ],
  },
  { href: '/about-us',   label: 'About us' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/resources', label: 'Resources' },
  { href: '/impression', label: 'Impression' },
  { href: '/contact',    label: 'Contact' },
];
---
<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-500 bg-transparent"
>
  <div class="container-content flex h-16 items-center justify-between md:h-20">

    <!-- Logo -->
    <a href="/" id="nav-logo" class="flex items-center gap-3 font-bold font-display tracking-tight transition-all duration-300 hover:scale-105 group">
      <span class="hidden sm:inline text-base md:text-lg bg-gradient-to-r from-ink via-accent to-warm bg-clip-text text-transparent group-hover:from-accent group-hover:to-ink transition-all duration-300">StartMonday<span class="bg-gradient-to-r from-accent to-warm bg-clip-text text-transparent">.AI</span></span>
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden md:flex items-center gap-7">
      {navLinks.map(l => (
        l.children ? (
          <div class="dropdown-wrap relative" role="none">
            <a
              href={l.href}
              aria-current={isActive(l.href) ? 'page' : undefined}
              aria-haspopup="true"
              class:list={[
                'nav-link text-sm font-medium transition-colors duration-200 pb-0.5 inline-flex items-center gap-1',
                isActive(l.href)
                  ? 'text-ink border-b-2 border-accent'
                  : 'text-graphite hover:text-ink border-b-2 border-transparent',
              ]}
            >
              {l.label}
              <svg class="dropdown-chevron w-3.5 h-3.5 mt-px transition-transform duration-200" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 6l4 4 4-4"/>
              </svg>
            </a>

            <div class="dropdown-panel absolute left-1/2 -translate-x-1/2 top-full mt-3 w-56 rounded-2xl bg-surface border border-line/60 shadow-[0_8px_32px_-4px_rgba(14,36,32,0.13)] py-1.5 z-50">
              <div class="absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-2 overflow-hidden">
                <div class="w-3 h-3 bg-surface border-l border-t border-line/60 rotate-45 mx-auto mt-1"></div>
              </div>
              <a href={l.href} class:list={['dropdown-item group/item flex items-center gap-2.5 px-4 py-2.5 text-sm font-semibold transition-colors', isActive(l.href) ? 'text-accent' : 'text-ink hover:text-accent hover:bg-accent-soft/50']}>
                All Services
              </a>
              <div class="mx-4 my-1 border-t border-line/50"></div>
              {l.children.map(child => (
                <a
                  href={child.href}
                  aria-current={isActive(child.href) ? 'page' : undefined}
                  class:list={[
                    'dropdown-item flex items-center gap-2.5 px-4 py-2.5 text-sm transition-colors',
                    isActive(child.href)
                      ? 'text-accent font-medium bg-accent-soft/40'
                      : 'text-graphite hover:text-ink hover:bg-accent-soft/50',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={l.href}
            aria-current={isActive(l.href) ? 'page' : undefined}
            class:list={[
              'nav-link text-sm font-medium transition-colors duration-200 pb-0.5',
              isActive(l.href)
                ? 'text-ink border-b-2 border-accent'
                : 'text-graphite hover:text-ink border-b-2 border-transparent',
            ]}
          >{l.label}</a>
        )
      ))}
      <a href="/sign-up" id="nav-cta" class="btn btn-primary !py-2 !px-5 text-sm">Sign up</a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
      class="md:hidden p-2 -mr-2 rounded text-ink transition-colors hover:bg-mist"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 6h18M3 12h18M3 18h18"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile full-screen overlay menu -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
  class="fixed inset-0 z-50 flex flex-col bg-ink opacity-0 pointer-events-none"
  style="transition: opacity 0.28s cubic-bezier(0.22,1,0.36,1);"
>
  <!-- Top bar -->
  <div class="flex h-16 shrink-0 items-center justify-between px-6 border-b border-paper/10">
    <a href="/" class="flex items-center gap-2.5 font-bold font-display text-paper">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-accent text-paper text-xs font-bold">SM</span>
      <span class="text-lg">StartMonday<span class="text-amber">.AI</span></span>
    </a>
    <button
      id="menu-close"
      aria-label="Close navigation menu"
      class="p-2 -mr-2 text-paper/60 hover:text-paper transition-colors rounded"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav aria-label="Primary mobile" class="flex flex-1 flex-col justify-center px-8 gap-0 overflow-y-auto">
    {navLinks.map(l => (
      l.children ? (
        <div class="border-b border-paper/10">
          <a
            href={l.href}
            aria-current={isActive(l.href) ? 'page' : undefined}
            class:list={[
              'py-5 text-2xl font-bold font-display transition-colors flex items-center gap-2',
              isActive(l.href) ? 'text-amber' : 'text-paper/80 hover:text-paper',
            ]}
          >{l.label}</a>
          <div class="flex flex-col gap-0 pb-4 -mt-2">
            {l.children.map(child => (
              <a
                href={child.href}
                aria-current={isActive(child.href) ? 'page' : undefined}
                class:list={[
                  'py-2 pl-4 text-base transition-colors border-l-2',
                  isActive(child.href)
                    ? 'text-amber border-amber'
                    : 'text-paper/50 hover:text-paper/80 border-paper/20',
                ]}
              >{child.label}</a>
            ))}
          </div>
        </div>
      ) : (
        <a
          href={l.href}
          aria-current={isActive(l.href) ? 'page' : undefined}
          class:list={[
            'border-b border-paper/10 py-5 text-2xl font-bold font-display transition-colors',
            isActive(l.href) ? 'text-amber' : 'text-paper/80 hover:text-paper',
          ]}
        >{l.label}</a>
      )
    ))}
    <div class="mt-8">
      <a href="/sign-up" class="btn btn-accent">Sign up</a>
    </div>
  </nav>
</div>

<!-- Mobile menu toggle script (all pages) -->
<script is:inline>
  (function () {
    var btn   = document.getElementById('menu-btn');
    var close = document.getElementById('menu-close');
    var menu  = document.getElementById('mobile-menu');
    if (!btn || !close || !menu) return;

    function open() {
      menu.style.opacity = '1';
      menu.style.pointerEvents = 'auto';
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      var first = menu.querySelector('a, button');
      if (first) first.focus();
    }

    function closeMenu() {
      menu.style.opacity = '0';
      menu.style.pointerEvents = 'none';
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      btn.focus();
    }

    btn.addEventListener('click', open);
    close.addEventListener('click', closeMenu);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.style.pointerEvents === 'auto') closeMenu();
    });
  })();
</script>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    if (!header) return;
    function onScroll() {
      header.classList.toggle('header-scrolled', window.scrollY > 20);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>

<style>
  /* Dropdown panel — hidden by default, shown on hover/focus-within */
  .dropdown-panel {
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(6px);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .dropdown-wrap:hover .dropdown-panel,
  .dropdown-wrap:focus-within .dropdown-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-wrap:hover .dropdown-chevron,
  .dropdown-wrap:focus-within .dropdown-chevron {
    transform: rotate(180deg);
  }

  .btn-outline-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 999px;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    border: 1.5px solid rgba(255,255,255,0.45);
    color: #fff;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(6px);
    transition: all 0.22s cubic-bezier(0.22,1,0.36,1);
  }
  .btn-outline-hero:hover {
    background: rgba(255,255,255,0.16);
    border-color: rgba(255,255,255,0.85);
    transform: translateY(-1px);
  }

  /* Scroll-aware header */
  #site-header.header-scrolled {
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 20px -1px rgba(14, 14, 44, 0.06);
    border-bottom: 1px solid rgba(208, 232, 227, 0.7);
  }

  /* Nav link hover underline */
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    height: 1px;
    width: 0;
    background: #2B7D6D;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>
